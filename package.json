{
  "name": "patchlane",
  "version": "0.2.4",
  "description": "CLI tool for maintaining forked repositories with custom patches",
  "type": "module",
  "bin": {
    "patchlane": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node --experimental-strip-types ./scripts/sync-skill-assets.ts && tsc -p tsconfig.json",
    "test": "npm run build && tsc -p tsconfig.test.json && vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adampoit/patchlane.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "cac": "^7.0.0"
  }
}
